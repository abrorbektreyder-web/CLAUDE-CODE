# ════════════════════════════════════════════════════════════════════════════
# DATABASE
# ════════════════════════════════════════════════════════════════════════════

# Supabase Transaction Pooler URL (port 6543) — REQUIRED for serverless
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR-PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# Direct connection (port 5432) — for migrations only
DIRECT_DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR-PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"


# ════════════════════════════════════════════════════════════════════════════
# ENCRYPTION
# ════════════════════════════════════════════════════════════════════════════

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your-32-character-encryption-key-here-replace-this"


# ════════════════════════════════════════════════════════════════════════════
# AUTH (Better Auth)
# ════════════════════════════════════════════════════════════════════════════

# Secret for signing tokens (Generate: openssl rand -hex 32)
BETTER_AUTH_SECRET="your-better-auth-secret-replace-with-random-hex"

# Base URL where the app is hosted
BETTER_AUTH_URL="http://localhost:3000"


# ════════════════════════════════════════════════════════════════════════════
# APP
# ════════════════════════════════════════════════════════════════════════════

# Public URL (use http://localhost:3000 in dev, https://poshub.uz in prod)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Domain for subdomain routing (e.g., {tenant}.poshub.uz)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"


# ════════════════════════════════════════════════════════════════════════════
# TELEGRAM (for 2FA + notifications)
# ════════════════════════════════════════════════════════════════════════════

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN="0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TELEGRAM_BOT_USERNAME="your_bot_username"

# Webhook URL (must be HTTPS in production)
TELEGRAM_WEBHOOK_URL="https://poshub.uz/api/webhooks/telegram"

# Webhook secret for verifying Telegram requests
TELEGRAM_WEBHOOK_SECRET="random-secret-for-telegram"


# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL — REDIS (for caching & rate limiting)
# ════════════════════════════════════════════════════════════════════════════

# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""


# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL — STORAGE
# ════════════════════════════════════════════════════════════════════════════

# Supabase Storage settings (or use Cloudflare R2)
# SUPABASE_STORAGE_URL=""
# SUPABASE_STORAGE_KEY=""


# ════════════════════════════════════════════════════════════════════════════
# OPTIONAL — EMAIL (Resend)
# ════════════════════════════════════════════════════════════════════════════

# RESEND_API_KEY=""
# EMAIL_FROM="noreply@poshub.uz"
